// prisma/schema.prisma
// Multi-tenant Photo SaaS Platform
// Every table scoped by tenantId for complete data isolation

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// TENANT (one per organization/business)
// ─────────────────────────────────────────
model Tenant {
  id          String   @id @default(cuid())
  name        String                          // "John Photography" / "ABC School"
  slug        String   @unique               // "john-photography" → john-photography.yourapp.com
  logoUrl     String?
  plan        Plan     @default(FREE)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  users       User[]
  events      Event[]
  members     Member[]
  photos      Photo[]

  @@map("tenants")
}

// ─────────────────────────────────────────
// USER (staff/admin inside a tenant)
// ─────────────────────────────────────────
model User {
  id           String    @id @default(cuid())
  tenantId     String
  email        String
  passwordHash String
  name         String
  role         UserRole  @default(STAFF)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessions     Session[]
  events       Event[]
  photos       Photo[]

  // Email must be unique within a tenant, not globally
  @@unique([tenantId, email])
  @@map("users")
}

// ─────────────────────────────────────────
// SESSION (JWT token tracking)
// ─────────────────────────────────────────
model Session {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ─────────────────────────────────────────
// EVENT (photo event per tenant)
// ─────────────────────────────────────────
model Event {
  id          String      @id @default(cuid())
  tenantId    String
  name        String
  description String?
  date        DateTime
  coverUrl    String?
  isPublic    Boolean     @default(false)
  status      EventStatus @default(ACTIVE)
  inviteCode  String      @unique @default(cuid())  // used in /join/[inviteCode] self-join link
  createdById String                                  // which user created this event
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy   User        @relation(fields: [createdById], references: [id])
  members     Member[]
  photos      Photo[]

  @@map("events")
}

// ─────────────────────────────────────────
// PHOTO (uploaded image, stored on Cloudinary)
// ─────────────────────────────────────────
model Photo {
  id           String   @id @default(cuid())
  tenantId     String
  eventId      String
  url          String                    // Cloudinary secure_url — full resolution
  thumbnailUrl String                    // Cloudinary auto-cropped/compressed thumbnail
  publicId     String                    // Cloudinary public_id — needed to delete the asset later
  width        Int
  height       Int
  bytes        Int                       // file size, used for storage usage tracking
  order        Int      @default(0)      // upload order, used since captions were skipped for MVP
  uploadedById String
  createdAt    DateTime @default(now())

  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])

  @@index([eventId])
  @@map("photos")
}

// ─────────────────────────────────────────
// MEMBER (end-user who views/downloads photos)
// ─────────────────────────────────────────
model Member {
  id            String     @id @default(cuid())
  tenantId      String
  eventId       String?
  name          String
  email         String?
  phone         String?
  emailVerified Boolean    @default(false) // true once OTP confirmed (self-join only; manual adds skip this)
  selfieUrl     String?    // for face recognition
  joinedVia     JoinMethod @default(MANUAL)
  createdAt     DateTime   @default(now())

  tenant        Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  event         Event?     @relation(fields: [eventId], references: [id])

  // Prevent the same email from joining the same event twice (when email is provided)
  @@unique([eventId, email])
  @@map("members")
}

// ─────────────────────────────────────────
// OTP VERIFICATION (email OTP for self-join flow)
// ─────────────────────────────────────────
// Short-lived, single-purpose codes. Not tied to a Member yet — verification
// happens BEFORE a Member record is created, so the join form can't be
// submitted with an unverified email.
model OtpVerification {
  id        String   @id @default(cuid())
  eventId   String                          // which event's join flow this OTP belongs to
  email     String
  code      String                          // 6-digit code, hashed not stored in plain text
  verified  Boolean  @default(false)
  attempts  Int      @default(0)            // failed verify attempts, capped to prevent brute force
  expiresAt DateTime
  createdAt DateTime @default(now())

  // One active OTP per (event, email) pair — re-requesting overwrites the old one
  @@unique([eventId, email])
  @@map("otp_verifications")
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────
enum Plan {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum UserRole {
  OWNER       // full access, billing
  ADMIN       // manage events, members, users
  STAFF       // upload photos, manage events
  VIEWER      // read only
}

enum EventStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

enum JoinMethod {
  MANUAL    // added by owner/staff
  SELF_JOIN // joined via invite link
}
