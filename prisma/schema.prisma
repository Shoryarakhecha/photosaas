// prisma/schema.prisma
// Multi-tenant Photo SaaS Platform
// Every table scoped by tenantId for complete data isolation

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// TENANT (one per organization/business)
// ─────────────────────────────────────────
model Tenant {
  id          String   @id @default(cuid())
  name        String                          // "John Photography" / "ABC School"
  slug        String   @unique               // "john-photography" → john-photography.yourapp.com
  logoUrl     String?
  plan        Plan     @default(FREE)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  users       User[]
  events      Event[]
  members     Member[]

  @@map("tenants")
}

// ─────────────────────────────────────────
// USER (staff/admin inside a tenant)
// ─────────────────────────────────────────
model User {
  id           String    @id @default(cuid())
  tenantId     String
  email        String
  passwordHash String
  name         String
  role         UserRole  @default(STAFF)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessions     Session[]

  // Email must be unique within a tenant, not globally
  @@unique([tenantId, email])
  @@map("users")
}

// ─────────────────────────────────────────
// SESSION (JWT token tracking)
// ─────────────────────────────────────────
model Session {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ─────────────────────────────────────────
// EVENT (photo event per tenant)
// ─────────────────────────────────────────
model Event {
  id          String      @id @default(cuid())
  tenantId    String
  name        String
  description String?
  date        DateTime
  coverUrl    String?
  isPublic    Boolean     @default(false)
  status      EventStatus @default(ACTIVE)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  members     Member[]

  @@map("events")
}

// ─────────────────────────────────────────
// MEMBER (end-user who views/downloads photos)
// ─────────────────────────────────────────
model Member {
  id        String   @id @default(cuid())
  tenantId  String
  eventId   String?
  name      String
  email     String?
  phone     String?
  selfieUrl String?  // for face recognition
  createdAt DateTime @default(now())

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  event     Event?   @relation(fields: [eventId], references: [id])

  @@map("members")
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────
enum Plan {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum UserRole {
  OWNER       // full access, billing
  ADMIN       // manage events, members, users
  STAFF       // upload photos, manage events
  VIEWER      // read only
}

enum EventStatus {
  ACTIVE
  ARCHIVED
  DELETED
}
