# ─────────────────────────────────────────
# DATABASE (Supabase PostgreSQL)
# ─────────────────────────────────────────
# Get this from: https://supabase.com → Project → Settings → Database → Connection string
# Use the "URI" format, replace [YOUR-PASSWORD] with your DB password
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# ─────────────────────────────────────────
# JWT SECRET
# ─────────────────────────────────────────
# Generate a strong random secret:
# Run in terminal: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# ─────────────────────────────────────────
# APP
# ─────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="PhotoSaaS"

# ─────────────────────────────────────────
# CLOUDINARY (photo storage — Step 3)
# ─────────────────────────────────────────
# Get these from: https://cloudinary.com/console (Dashboard home page)
# No credit card required for the free tier (25GB storage / 25GB bandwidth)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ─────────────────────────────────────────
# EMAIL OTP (Gmail SMTP — Step 3.5)
# ─────────────────────────────────────────
# 1. Turn on 2-Step Verification on your Gmail account
# 2. Go to: Google Account → Security → App Passwords → generate one for "Mail"
# 3. Use that 16-character app password below (NOT your normal Gmail password)
GMAIL_USER="youraddress@gmail.com"
GMAIL_APP_PASSWORD="your-16-char-app-password"

# ─────────────────────────────────────────
# GMAIL SMTP (email OTP — Step 3.5)
# ─────────────────────────────────────────
# 1. Go to your Google Account → Security → 2-Step Verification (turn ON)
# 2. Then Security → App passwords → generate one for "Mail"
# 3. Use that 16-character value below (NOT your normal Gmail password)
GMAIL_USER="youraddress@gmail.com"
GMAIL_APP_PASSWORD=""
